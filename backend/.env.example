# ── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Authentication ────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
API_KEY_SECRET=change-me-in-production
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=24h

# ── Database ──────────────────────────────────────────────────────────────────
# In dev the app uses an in-memory store — set this for production Postgres
DATABASE_URL=mongodb+srv://bbbkh:bbbb@00@cluster0.jii71tl.mongodb.net/taxflow


# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Use * for dev only.
ALLOWED_ORIGINS=http://localhost:3001,https://yourdashboard.com


# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# ── Webhooks ──────────────────────────────────────────────────────────────────
WEBHOOK_TIMEOUT_MS=5000
WEBHOOK_RETRY_ATTEMPTS=3

# ── Simulation ────────────────────────────────────────────────────────────────
SIMULATION_MAX_PERIODS=60

# ── Risk thresholds ───────────────────────────────────────────────────────────
DEFAULT_RISK_HIGH_THRESHOLD=0.75
DEFAULT_RISK_MEDIUM_THRESHOLD=0.40
